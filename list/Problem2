# PROBLEM 2
# Slice the Marks
# Given 

# marks = [45, 67, 89, 23, 90, 56, 78] :
# Print the first 3 marks
# Print the last 2 marks
# Print every alternate mark
# Print the list in reverse

marks = [45, 67, 89, 23, 90, 56, 78]

print(f"First three marks --> {marks[:3:1]}")
print(f"Last 2 marks --> {marks[-2:]}")
print(f"Every Alternative marks --> {marks[::2]}")
print(f"Reverse of  marks --> {marks[::-1]}")
