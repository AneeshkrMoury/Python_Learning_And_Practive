# Unique Words Counter
# Take a sentence from the user. Split it into words and print how many unique
# words it contains (ignore repeats).

s = input("Enter a sentence : ")
s = s.replace(" ", "")
s = set(s)
print(f"number of unique words in entered sentence -->>> {len(s)}")

# Who Dropped Out?
# registered = {"A", "B", "C", "D", "E"} signed up, but attended = {"A", "C","E"} showed up. Use set difference to find who did NOT attend

registered = {"A", "B", "C", "D", "E"}
attended = {"A", "C","E"}
print(f"Not attended : {registered - attended}")

